{
  "name": "fork-version",
  "version": "4.1.10",
  "license": "MIT",
  "description": "Fork-Version automates version control tasks such as determining, updating, and committing versions, files, and changelogs, simplifying the process when adhering to the conventional commit standard.",
  "keywords": [
    "changelog",
    "commit",
    "conventional changelog",
    "conventional commits",
    "git",
    "metadata",
    "semantic version",
    "semantic",
    "semver",
    "tag",
    "version"
  ],
  "homepage": "https://github.com/eglavin/fork-version",
  "bugs": {
    "url": "https://github.com/eglavin/fork-version/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eglavin/fork-version.git"
  },
  "author": {
    "name": "Eanna Glavin",
    "url": "https://eglavin.com"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "private": false,
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "fork-version": "dist/cli.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "fork-version": "node dist/cli.js",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "update-json-schema": "node scripts/update-json-schema.js",
    "update-readme-cli-options": "node scripts/update-readme-cli-options.js",
    "lint": "eslint --fix \"src/**/*.{js,ts}\"",
    "lint:check": "eslint \"src/**/*.{js,ts}\"",
    "lint:format": "prettier --write \"src/**/*.{js,ts}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:cover": "vitest --coverage",
    "test:ci": "vitest run --coverage --no-file-parallelism",
    "test:ui": "vitest --ui",
    "test:cleanup": "rimraf -g ../fork-version.tests/*"
  },
  "dependencies": {
    "bundle-require": "5.1.0",
    "cheerio": "1.2.0",
    "conventional-changelog": "5.1.0",
    "conventional-changelog-config-spec": "2.1.0",
    "conventional-changelog-conventionalcommits": "7.0.2",
    "esbuild": "0.28.0",
    "joycon": "3.1.1",
    "jsonc-parser": "3.3.1",
    "meow": "14.1.0",
    "semver": "7.7.4",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.2",
    "@eslint/js": "10.0.1",
    "@types/json-schema": "7.0.15",
    "@types/node": "24.11.0",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "4.1.2",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "rimraf": "6.1.3",
    "tsdown": "0.21.7",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vitest": "4.1.2"
  }
}
